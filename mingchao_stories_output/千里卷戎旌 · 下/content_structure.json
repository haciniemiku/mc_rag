    "4da666b5-0c1f-489c-b926-74cbe89f21a2": {
      "v": "v1",
      "flow": {
        "raw": [
          {
            "id": "1",
            "cid": [
              "2-1",
              "2-2"
            ],
            "title": "",
            "content": "<p>忌炎：身为战争的鸣式，不选择战斗到底&hellip;&hellip;反而选择了逃跑吗？</p>"
          },
          {
            "id": "2-1",
            "cid": [
              "3-1"
            ],
            "pid": [
              "1"
            ],
            "group": "2",
            "title": "它看起来很虚弱。",
            "content": ""
          },
          {
            "id": "2-2",
            "cid": [
              "3-1"
            ],
            "pid": [
              "1"
            ],
            "group": "2",
            "title": "它在有意避战。",
            "content": "",
            "delEdgeChildren": []
          },
          {
            "id": "3-1",
            "cid": [],
            "pid": [
              "2-1",
              "2-2"
            ],
            "group": "3",
            "title": "",
            "content": "<div class=\"\">\n<p class=\"py-1 px-2 align-middle\">？？：呼&hellip;&hellip;呼&hellip;&hellip;</p>\n</div>\n<div class=\"\">\n<p class=\"py-1 px-2 align-middle\">忌炎：漂泊者，这是&hellip;&hellip;</p>\n</div>\n<div class=\"\">\n<p class=\"py-1 px-2 align-middle\">忌炎：这个地方要崩塌了&hellip;&hellip;我们先离开这里，其他事情出去再议。</p>\n</div>"
          }
        ],
        "data": {},
        "structure": {
          "id": "1"
        },
        "individual": []
      },
