          "titleDisabled": true
        },
        {
          "title": "继续与涅索交谈，了解关于总督的叙诗",
          "components": [
            {
              "idx": "0fd316a9-1b0e-42aa-a346-b82bbf6e9b0f",
              "size": "frameless",
              "type": "story-component",
              "title": "剧情组件-无边框",
              "content": "",
              "collapse": false,
              "titleStyle": {
                "color": "#333",
                "opacity": "100%",
                "textAlign": "left",
                "backgroundColor": "transparent",
                "backgroundImage": "",
                "backgroundPositionX": "100%",
                "backgroundPositionY": "0",
                "backgroundImageWidth": 0,
                "backgroundImageHeight": 0
              }
            }
          ],
          "titleDisabled": true
