        {
          "title": "与涅索交谈，了解关于总督的叙诗",
          "components": [
            {
              "idx": "bf525fd6-130e-48b7-a0c2-63cc5ab7688d",
              "size": "frameless",
              "type": "story-component",
              "title": "剧情组件-无边框",
