      "story": {
        "15052a3d-7be3-4fbf-b6bf-e55c5f0ca453": {
          "v": "v1",
          "flow": {
            "raw": [
              {
                "id": "1",
                "cid": [],
                "pid": [],
                "title": "",
                "content": "<div>\n<p class=\"plot-p-unit py-1 px-2 text-neutral-400\"><span class=\"\">洄游鱼向你展示了此处曾经的景象&mdash;&mdash;</span></p>\n</div>\n<div>\n<p class=\"plot-p-unit py-1 px-2 text-neutral-400\"><span class=\"\">少女倚靠着围栏眺望远方，目光深陷在湛蓝的天空。她究竟在思考什么呢&hellip;&hellip;</span></p>\n</div>"
              }
            ],
            "data": {},
            "structure": {
              "id": "1"
            },
            "individual": []
          },
          "title": "",
          "branch": "1",
          "content": "",
