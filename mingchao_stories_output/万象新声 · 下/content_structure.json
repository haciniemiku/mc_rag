  "story": {
    "20944610-113b-4804-a8da-c8c11288b016": {
      "v": "v1",
      "flow": {
        "raw": [
          {
            "id": "1",
            "cid": [],
            "title": "",
            "content": "<p>炽霞：唔&hellip;&hellip;看来终端虽然样式不同，但和我们的终端功能基本上差不多嘛。</p>"
          }
        ],
        "data": {},
        "structure": {
          "id": "1"
        },
        "individual": []
      },
      "title": "",
      "branch": "1",
      "content": "",
